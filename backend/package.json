{
    "name": "ecommerce-recommendation-backend",
    "version": "1.0.0",
    "description": "ML Recommendation System Backend with TensorFlow.js and pgvector. Database migrations and seeders for Node.js",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node --expose-gc --max-old-space-size=4096 server.js",
        "dev": "nodemon --expose-gc --max-old-space-size=4096 server.js",
        "db:reset": "knex migrate:rollback && knex migrate:latest && knex seed:run",
        "db:setup": "npm run migrate:latest && npm run db:seed",
        "migrate:latest": "knex migrate:latest",
        "migrate:refresh": "npm run migrate:rollback && npm run migrate:latest  && npm run vector:setup",
        "migrate:rollback": "knex migrate:rollback",
        "db:seed": "knex seed:run",
        "vector:setup": "node database/scripts/setup-vector.js",
        "vector:setup:bash": "bash database/scripts/setup-vector.sh",
        "vector:check": "node database/scripts/check-pgvector.js"
    },
    "dependencies": {
        "@tensorflow/tfjs-node-gpu": "^4.22.0",
        "express": "^4.18.2",
        "cors": "^2.8.5",
        "ws": "^8.14.2",
        "pg": "^8.11.3",
        "dotenv": "^16.3.1",
        "knex": "^3.0.0",
        "faker": "^5.5.3",
        "@faker-js/faker": "^8.3.0",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "dotenv": "^16.3.0",
        "nodemon": "^3.0.1"
    }
}